# Copy to .env.local and fill in.

# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET=
# Public URL of the app. Auth.js uses this to build callback URLs.
# Local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# --- Google OAuth ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Database ---
# Neon connection string. Include ?sslmode=require.
DATABASE_URL=

# --- App crypto ---
# 32-byte key, base64-encoded. Generate with:
#   openssl rand -base64 32
MASTER_ENCRYPTION_KEY=

# --- Gmail Pub/Sub ---
# Full topic name that Gmail will publish to when watch-ed mailboxes change.
# Format: projects/<PROJECT_ID>/topics/<TOPIC_NAME>
GOOGLE_PUBSUB_TOPIC=
# Service account email that Pub/Sub uses to sign push-subscription OIDC tokens.
# Set on the push subscription in GCP Console → Pub/Sub → Subscriptions → Edit.
GOOGLE_PUBSUB_SA_EMAIL=

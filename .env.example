# Copy to .env.local and fill in.

# --- Auth.js ---
# Generate with: npx auth secret
AUTH_SECRET=
# Public URL of the app. Auth.js uses this to build callback URLs.
# Local dev: http://localhost:3000
AUTH_URL=http://localhost:3000

# --- Google OAuth ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Database ---
# Neon connection string. Include ?sslmode=require.
DATABASE_URL=

# --- App crypto ---
# 32-byte key, base64-encoded. Generate with:
#   openssl rand -base64 32
MASTER_ENCRYPTION_KEY=
